{
  "name": "dipsaus-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source toolkit of Claude / AI-CLI skills + an MCP, packaged as a single Claude Code plugin, with an eval harness that tests each skill against the author's standards.",
  "license": "MIT",
  "author": "dipsaus9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dipsaus9/dipsaus-ai.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
