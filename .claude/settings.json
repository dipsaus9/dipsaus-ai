{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "worktree": {
    "baseRef": "fresh"
  },
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun run lint)",
      "Bash(bun run typecheck)",
      "Bash(bun run test)",
      "Bash(backlog status*)",
      "Bash(backlog task *)",
      "Bash(backlog subtask *)",
      "Bash(backlog doctor)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ]
  }
}
